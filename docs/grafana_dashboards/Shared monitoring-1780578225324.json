            "group": "prometheus",
            "version": "v0",
            "datasource": {
              "name": "feqx8avvem5mob"
            },
            "spec": {
              "expr": "group by (namespace, container, image) (\n  changes(\n    count by (namespace, container, image) (\n      kube_pod_container_info{namespace=~\"$namespace\"}\n    )[2m:30s]\n  ) > 0\n)",
              "interval": "",
              "refId": "Anno"
            }
          },
          "enable": true,
          "hide": false,
          "iconColor": "green",
          "name": "Changement image"
        }
      },
      {
        "kind": "AnnotationQuery",
        "spec": {
          "query": {
            "kind": "DataQuery",
            "group": "prometheus",
            "version": "v0",
            "datasource": {
              "name": "feqx8avvem5mob"
            },
            "spec": {
              "expr": "group by (namespace, deployment) (\n  (kube_deployment_status_replicas_unavailable{namespace=~\"$namespace\"} == 0)\n  unless\n  (kube_deployment_status_replicas_unavailable{namespace=~\"$namespace\"} offset 2m == 0)\n)",
              "interval": "",
              "refId": "Anno"
            }
          },
          "enable": true,
          "hide": false,
          "iconColor": "dark-blue",
          "name": "Rollout end"
