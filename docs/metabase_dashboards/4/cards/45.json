    "stages": [
      {
        "lib/type": "mbql.stage/native",
        "native": "SELECT\n  COUNT(DISTINCT (re.\"requeteId\", re.\"entiteId\")) AS nombre_requetes\nFROM\n  \"RequeteEntite\" re\n  JOIN \"Entite\" e ON e.id = re.\"entiteId\"\n  JOIN \"RequeteEtape\" cloture ON cloture.\"requeteId\" = re.\"requeteId\"\n  AND cloture.\"entiteId\" = re.\"entiteId\"\n  AND cloture.\"statutId\" = 'CLOTUREE'\nWHERE\n  re.\"statutId\" = 'CLOTUREE'\n  [[ AND e.label = {{entity_label}} ]]\n  [[ AND cloture.\"createdAt\" >= {{start_date}} ]]\n  [[ AND cloture.\"createdAt\" <  ({{end_date}}::date + INTERVAL '1 day') ]];",
