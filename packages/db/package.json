{
  "name": "@sirena/db",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "generate": "prisma generate --generator client",
    "migrate": "DISABLE_ERD=true prisma migrate dev",
    "studio": "prisma studio",
    "deploy": "prisma migrate deploy",
    "migrate:resolve": "prisma migrate resolve --rolled-back",
    "reset": "DISABLE_ERD=true prisma migrate reset",
    "erd": "node scripts/erd/generate.mjs",
    "erd:check": "node scripts/erd/check.mjs",
    "lint": "biome check",
    "build": "tsc"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "./generated-client": {
      "import": {
        "types": "./dist/generated/prisma/client.d.ts",
        "default": "./dist/generated/prisma/client.js"
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "dotenv": "catalog:",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "prisma": "catalog:",
    "prisma-erd-generator": "^2.4.4",
    "typescript": "catalog:"
  }
}
