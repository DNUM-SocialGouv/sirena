  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ],
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "lodash": ">=4.17.23",
      "fast-xml-parser@>=4.3.6 <=5.3.3": ">=5.3.4",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
