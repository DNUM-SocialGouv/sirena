{
  "name": "sirena",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "migration:start": "dotenv -e .env -- pnpm --filter @sirena/migration start",
    "migration:enqueue": "dotenv -e .env -- pnpm --filter @sirena/migration enqueue",
    "build:backend": "pnpm --filter @sirena/backend build",
    "build:frontend": "pnpm --filter @sirena/frontend build",
    "build:backend-utils": "pnpm --filter @sirena/backend-utils build",
    "build:common": "pnpm --filter @sirena/common build",
    "build:db": "pnpm --filter @sirena/db build",
    "dev": "pnpm dev:frontend & pnpm dev:backend & pnpm dev:backend-utils & pnpm dev:common",
    "dev:frontend": "dotenv -e .env -- pnpm --filter @sirena/frontend dev",
    "dev:backend-utils": "pnpm --filter @sirena/backend-utils dev",
    "dev:common": "pnpm --filter @sirena/common dev",
    "dev:backend": "dotenv -e .env -- pnpm --filter @sirena/backend dev",
    "dev:worker": "dotenv -e .env -- pnpm --filter @sirena/backend worker",
    "dev:ui": "pnpm --filter @sirena/ui storybook",
    "db:studio": "dotenv -e .env -- pnpm --filter @sirena/db studio",
    "db:migrate": "dotenv -e .env -- pnpm --filter @sirena/db migrate",
    "op:import:geodata": "dotenv -e .env -- pnpm --filter @sirena/backend op:import:geodata",
    "op:diff:enums": "dotenv -e .env -- pnpm --filter @sirena/backend op:diff:enums",
    "op:diff:entites:analyze": "dotenv -e .env -- pnpm --filter @sirena/backend op:diff:entites:analyze",
    "op:diff:entites:up": "dotenv -e .env -- pnpm --filter @sirena/backend op:diff:entites:up",
    "op:diff:entites:down": "dotenv -e .env -- pnpm --filter @sirena/backend op:diff:entites:down",
    "op:import:dematsocial": "dotenv -e .env -- pnpm --filter @sirena/backend op:import:dematsocial",
    "op:manage-api-keys": "dotenv -e .env -- pnpm --filter @sirena/backend op:manage-api-keys",
    "op:file-integrity": "dotenv -e .env -- pnpm --filter @sirena/backend op:file-integrity",
    "db:deploy": "dotenv -e .env -- pnpm --filter @sirena/db run deploy",
    "db:generate": "dotenv -e .env -- pnpm --filter @sirena/db generate",
    "db:reset": "dotenv -e .env -- pnpm --filter @sirena/db reset",
    "backend:codegen": "dotenv -e .env -- pnpm --filter @sirena/backend generate:codegen",
    "backend:gql": "dotenv -e .env -- pnpm --filter @sirena/backend gql",
    "backend:start": "dotenv -e .env -- pnpm --filter @sirena/backend start",
    "generate:openapi:thirdparty": "dotenv -e .env -- pnpm --filter @sirena/backend generate:openapi:thirdparty",
    "test:e2e": "pnpm --filter @sirena/frontend test:e2e",
    "test:e2e:ui": "pnpm --filter @sirena/frontend test:e2e:ui",
    "test:smoke": "dotenv -e .env -- pnpm --filter @sirena/backend test:smoke",
    "test:unit": "pnpm -r run test",
    "typecheck": "pnpm build:common && pnpm -r run typecheck",
    "gitleaks:detect-secrets": "bash .husky/gitleaks-detect-secrets.sh",
    "gitleaks:ci": "bash .husky/gitleaks-detect-secrets-ci.sh",
    "gitleaks:update-ignored-secrets": "bash .husky/gitleaks-update-ignored-secrets.sh",
    "lint": "pnpm -r run lint",
    "lint:staged": "pnpm -r run lint:staged",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@sentry/cli",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ],
    "overrides": {
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "lodash": ">=4.17.23",
      "fast-xml-parser@>=4.3.6 <=5.3.3": ">=5.3.4",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "minimatch@<10.2.1": ">=10.2.1",
      "graphql-config>minimatch": ">=10.2.3",
      "hono@<4.11.10": ">=4.11.10",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "fast-xml-parser@<5.3.8": ">=5.3.8",
      "immutable@<4.3.8": ">=4.3.8",
      "ioredis": ">=5.10.0",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2",
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": ">=5.5.7",
      "@hono/node-server@<1.19.10": ">=1.19.10",
      "effect@<3.20.0": ">=3.20.0",
      "micromatch>picomatch": "4.0.4",
      "vite>picomatch": "4.0.4",
      "vitest>picomatch": "4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  }
}
