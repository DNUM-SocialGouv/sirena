{
  "name": "@sirena/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "predev": "react-dsfr update-icons",
    "prebuild": "react-dsfr update-icons",
    "dev": "vite --host 0.0.0.0",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "vitest --typecheck",
    "build": "tsc -b && vite build",
    "build:analyze": "ANALYZE_BUNDLE=true vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "preview": "vite preview",
    "lint:staged": "git diff --cached --name-only --diff-filter=ACM | grep '^packages/frontend/' | sed 's|^packages/frontend/||' | grep -E '\\.(js|ts|tsx|jsx|json|md)$' | xargs -r pnpm biome check",
    "generate:openAPI": "tsx ./src/scripts/openAPI.ts"
  },
  "dependencies": {
    "@codegouvfr/react-dsfr": "catalog:",
    "@sentry/react": "^10.65.0",
    "@sirena/backend": "workspace:*",
    "@sirena/common": "workspace:*",
    "@sirena/ui": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "catalog:",
    "clsx": "catalog:",
    "hono": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "dotenv": "catalog:",
    "globals": "^17.7.0",
    "jsdom": "catalog:",
    "playwright": "^1.61.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
