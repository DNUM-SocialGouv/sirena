{
  "name": "@sirena/migration",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "tsx src/scripts/migrate.ts",
    "enqueue": "tsx src/scripts/enqueue.ts",
    "lint": "biome check",
    "lint:staged": "git diff --cached --name-only --diff-filter=ACM | grep '^apps/migration/' | sed 's|^apps/migration/||' | grep -E '\\.(js|ts|tsx|jsx|json|md)$' | xargs -r pnpm biome check"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@sirena/backend": "workspace:*",
    "@sirena/common": "workspace:*",
    "@sirena/db": "workspace:*",
    "bullmq": "^5.70.1",
    "ioredis": "^5.10.0",
    "mysql2": "^3.11.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "~5.9.3"
  }
}
